    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Get in Touch",
      "info": "Small uppercase label above the heading"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading",
      "default": "Contact Palliser Ridge"
