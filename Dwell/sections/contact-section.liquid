    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro text",
      "default": "<p>We'd love to hear from you. Whether you're planning a visit, looking to purchase our wool products, or have a general enquiry — reach out anytime.</p>"
    },
    {
      "type": "header",
      "content": "Address"
    },
    {
      "type": "text",
      "id": "address_title",
      "label": "Label",
      "default": "Find Us"
    },
    {
      "type": "richtext",
      "id": "address_text",
      "label": "Address",
      "default": "<p>226 Te Rata Road<br>RD2, Featherston 5772<br>New Zealand</p>"
    },
    {
      "type": "url",
      "id": "address_link",
      "label": "Google Maps link",
      "info": "Makes the address a clickable directions link"
    },
    {
      "type": "header",
      "content": "Email"
    },
    {
      "type": "text",
      "id": "email_title",
      "label": "Label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email address",
      "default": "info@palliserridge.co.nz"
    },
    {
      "type": "header",
      "content": "Phone"
    },
    {
      "type": "text",
      "id": "phone_title",
      "label": "Label",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "default": "+64 27 503 5145"
    },
    {
      "type": "header",
      "content": "Business Hours"
    },
    {
      "type": "checkbox",
      "id": "show_hours",
      "label": "Show hours",
      "default": false
    },
    {
      "type": "text",
      "id": "hours_title",
      "label": "Label",
      "default": "Hours"
    },
    {
      "type": "richtext",
      "id": "hours_text",
      "label": "Hours",
      "default": "<p>Monday – Friday: 9:00am – 5:00pm<br>Weekends: By appointment</p>"
    },
    {
      "type": "header",
      "content": "Additional Note"
    },
    {
      "type": "richtext",
      "id": "additional_info",
      "label": "Additional note",
      "info": "Optional small note below the contact details (italic, subtle)"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "checkbox",
      "id": "show_image",
      "label": "Show image",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "contact_image",
      "label": "Contact image"
    },
    {
      "type": "text",
      "id": "image_alt_text",
      "label": "Image alt text",
      "info": "Describe the image for accessibility"
