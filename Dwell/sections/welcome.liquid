{%- liquid
  assign column_ratio_class = 'welcome-section--' | append: section.settings.column_ratio
  assign content_alignment_class = 'welcome-section--content-' | append: section.settings.content_alignment
  assign vertical_alignment_class = 'welcome-section--vertical-' | append: section.settings.vertical_alignment
  assign column_direction_class = 'welcome-section--direction-' | append: section.settings.column_direction

  if section.settings.enable_animation
    assign animation_class = ' welcome-section--animated'
  else
    assign animation_class = ''
  endif
-%}

{% capture left_content %}
  {% if section.settings.left_image != blank %}
    <div class="welcome-section__image-wrapper">
      {{ section.settings.left_image | image_url: width: 800 | image_tag: widths: '400, 600, 800, 1000', sizes: '(max-width: 749px) 100vw, (max-width: 1024px) 50vw, 40vw', class: 'welcome-section__image', alt: 'Left column image', loading: 'lazy' }}
    </div>
  {% endif %}
{% endcapture %}

{% capture right_content %}
  {% if section.settings.main_heading != blank %}
    <h2 class="welcome-section__heading {{ section.settings.heading_size }}">
      {{ section.settings.main_heading }}
    </h2>
  {% endif %}

  {% if section.settings.sub_heading != blank %}
    <h3 class="welcome-section__sub-heading">
      {{ section.settings.sub_heading }}
    </h3>
  {% endif %}

  {% if section.settings.main_text != blank %}
    <div class="welcome-section__description rte">
      {{ section.settings.main_text }}
    </div>
  {% endif %}

  {% if section.settings.button_text != blank and section.settings.button_link != blank %}
    <a href="{{ section.settings.button_link }}" class="welcome-section__button button button--primary">
      {{ section.settings.button_text }}
    </a>
  {% endif %}
{% endcapture %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} welcome-section color-{{ section.settings.color_scheme }} spacing-style {{ column_ratio_class }} {{ content_alignment_class }} {{ vertical_alignment_class }} {{ column_direction_class }}{{ animation_class }}"
  style="
    {% render 'spacing-padding', settings: section.settings %}
    {% render 'border-override', settings: section.settings %}
    --column-gap: {{ section.settings.column_gap }}px;
    --image-border-radius: {{ section.settings.image_border_radius }}px;
    --welcome-heading-font: var(--font-{{ section.settings.heading_font }}--family, var(--font-heading-family));
    --welcome-text-font: var(--font-{{ section.settings.text_font }}--family, var(--font-body-family));
    --animation-delay: {{ section.settings.animation_delay }};
    --padding-block-start: {{ section.settings.padding-block-start }}px;
    --padding-block-end: {{ section.settings.padding-block-end }}px;
    --padding-block-start-mobile: {{ section.settings.padding-block-start-mobile }}px;
    --padding-block-end-mobile: {{ section.settings.padding-block-end-mobile }}px;
    --heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --subheading-size-desktop: {{ section.settings.subheading_size_desktop }}px;
    --subheading-size-mobile: {{ section.settings.subheading_size_mobile }}px;
    --text-size-desktop: {{ section.settings.text_size_desktop }}px;
    --text-size-mobile: {{ section.settings.text_size_mobile }}px;
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="welcome-section__grid">
    <div class="welcome-section__column welcome-section__column--left">
      {{ left_content }}
    </div>
    <div class="welcome-section__column welcome-section__column--right">
      {{ right_content }}
    </div>
  </div>
</div>

{% stylesheet %}
  .welcome-section {
    --animation-duration: 0.8s;
  }

  .welcome-section__grid {
    display: grid;
    gap: var(--column-gap);
    align-items: start;
  }

  .welcome-section--vertical-top .welcome-section__grid {
    align-items: start;
  }

  .welcome-section--vertical-center .welcome-section__grid {
    align-items: center;
  }

  .welcome-section--vertical-bottom .welcome-section__grid {
    align-items: end;
  }

  .welcome-section--equal .welcome-section__grid {
    grid-template-columns: 1fr 1fr;
  }

  .welcome-section--wide-left .welcome-section__grid {
    grid-template-columns: 3fr 2fr;
  }

  .welcome-section--wide-right .welcome-section__grid {
    grid-template-columns: 2fr 3fr;
  }

  .welcome-section--direction-reverse .welcome-section__grid {
    grid-template-columns: 1fr 1fr;
  }

  .welcome-section--direction-reverse.welcome-section--wide-left .welcome-section__grid {
    grid-template-columns: 2fr 3fr;
  }

  .welcome-section--direction-reverse.welcome-section--wide-right .welcome-section__grid {
    grid-template-columns: 3fr 2fr;
  }

  .welcome-section--content-left .welcome-section__column--left {
    text-align: left;
  }

  .welcome-section--content-center .welcome-section__column--left {
    text-align: center;
  }

  .welcome-section--content-right .welcome-section__column--left {
    text-align: right;
  }

  .welcome-section__column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .welcome-section__image-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: var(--image-border-radius);
  }

  .welcome-section__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .welcome-section__image-wrapper:hover .welcome-section__image {
    transform: scale(1.03);
  }

  .welcome-section__text,
  .welcome-section__description,
  .welcome-section .welcome-section__text,
  .welcome-section .welcome-section__description {
    font-size: var(--text-size-desktop, 16px) !important;
    line-height: 1.6;
    font-family: var(--welcome-text-font);
    font-weight: var(--welcome-text-font-weight);
    color: currentColor;
  }

  /* Target RTE content specifically */
  .welcome-section .rte,
  .welcome-section .rte p,
  .welcome-section .welcome-section__text.rte,
  .welcome-section .welcome-section__description.rte {
    font-size: var(--text-size-desktop, 16px) !important;
  }

  .welcome-section__heading,
  .welcome-section .welcome-section__heading {
    margin: 0 0 0.5rem 0;
    font-family: var(--welcome-heading-font);
    font-size: var(--heading-size-desktop, 48px) !important;
    line-height: 1.2;
    color: currentColor;
  }

  .welcome-section__sub-heading,
  .welcome-section .welcome-section__sub-heading {
    margin: 0;
    opacity: 0.8;
    font-family: var(--welcome-text-font);
    font-size: var(--subheading-size-desktop, 18px) !important;
    line-height: 1.3;
    color: currentColor;
  }

  .welcome-section__button {
    display: inline-flex;
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  .welcome-section--animated {
    opacity: 0;
    animation: fadeInUp var(--animation-duration) ease forwards;
    animation-delay: var(--animation-delay);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .welcome-section--animated {
      animation: none;
      opacity: 1;
    }
  }

  @media screen and (max-width: 749px) {
    .welcome-section__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .welcome-section__column {
      gap: 1rem;
    }

    .welcome-section--equal .welcome-section__grid,
    .welcome-section--content-left .welcome-section__grid,
    .welcome-section--content-right .welcome-section__grid {
      grid-template-columns: 1fr;
    }

    .welcome-section--content-left .welcome-section__button,
    .welcome-section--content-center .welcome-section__button,
    .welcome-section--content-right .welcome-section__button {
      align-self: flex-start;
    }

    /* Mobile padding overrides */
    .welcome-section {
      padding-block-start: var(--padding-block-start-mobile, var(--padding-block-start, 50px));
      padding-block-end: var(--padding-block-end-mobile, var(--padding-block-end, 50px));
    }

    /* Mobile typography overrides */
    .welcome-section__heading,
    .welcome-section .welcome-section__heading {
      font-size: var(--heading-size-mobile, 32px) !important;
    }

    .welcome-section__sub-heading,
    .welcome-section .welcome-section__sub-heading {
      font-size: var(--subheading-size-mobile, 16px) !important;
    }

    .welcome-section__text,
    .welcome-section__description,
    .welcome-section .welcome-section__text,
    .welcome-section .welcome-section__description {
      font-size: var(--text-size-mobile, 14px) !important;
    }

    /* Target RTE content on mobile */
    .welcome-section .rte,
    .welcome-section .rte p,
    .welcome-section .welcome-section__text.rte,
    .welcome-section .welcome-section__description.rte {
      font-size: var(--text-size-mobile, 14px) !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Welcome section",
  "tag": "section",
  "class": "section-welcome",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main heading",
      "default": "Welcome To Palliser Ridge"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h2"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Subheading",
      "default": "Pirinoa | South Wairarapa | New Zealand"
    },
    {
      "type": "richtext",
      "id": "main_text",
      "label": "Description",
      "default": "<p>Experience the authentic New Zealand rural lifestyle at our working sheep station. Our family has been farming this land for generations, and we're passionate about sharing our story with visitors.</p><p>From rolling hills to pristine coastline, discover the beauty of rural New Zealand.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Contact us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left column image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "column_ratio",
      "label": "Column ratio",
      "options": [
        { "value": "equal", "label": "Equal (50/50)" },
        { "value": "wide-left", "label": "Wide left (60/40)" },
        { "value": "wide-right", "label": "Wide right (40/60)" }
      ],
      "default": "equal"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "top"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "heading", "label": "Heading" },
        { "value": "body", "label": "Body" },
        { "value": "accent", "label": "Accent" }
      ],
      "default": "heading"
    },
    {
      "type": "select",
      "id": "text_font",
      "label": "Text font",
      "options": [
        { "value": "heading", "label": "Heading" },
        { "value": "body", "label": "Body" },
        { "value": "accent", "label": "Accent" }
      ],
      "default": "body"
    },
    {
      "type": "header",
      "content": "Typography Sizes - Desktop"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Main heading size (Desktop)",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48,
      "info": "Font size for main heading on desktop"
    },
    {
      "type": "range",
      "id": "subheading_size_desktop",
      "label": "Subheading size (Desktop)",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18,
      "info": "Font size for subheading on desktop"
    },
    {
      "type": "range",
      "id": "text_size_desktop",
      "label": "Body text size (Desktop)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16,
      "info": "Font size for description on desktop"
    },
    {
      "type": "header",
      "content": "Typography Sizes - Mobile"
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Main heading size (Mobile)",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32,
      "info": "Font size for main heading on mobile devices"
    },
    {
      "type": "range",
      "id": "subheading_size_mobile",
      "label": "Subheading size (Mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16,
      "info": "Font size for subheading on mobile devices"
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Body text size (Mobile)",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14,
      "info": "Font size for description on mobile devices"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable animation",
      "default": true
    },
    {
      "type": "select",
      "id": "animation_delay",
      "label": "Animation delay",
      "options": [
        { "value": "0s", "label": "No delay" },
        { "value": "0.2s", "label": "0.2s" },
        { "value": "0.4s", "label": "0.4s" },
        { "value": "0.6s", "label": "0.6s" }
      ],
      "default": "0.2s"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Welcome",
      "category": "Palliser Ridge Sections",
      "settings": {
        "main_heading": "Welcome To Palliser Ridge",
        "heading_size": "h2",
        "sub_heading": "Pirinoa | South Wairarapa | New Zealand",
        "button_text": "Contact us",
        "vertical_alignment": "top",
        "content_alignment": "left",
        "column_gap": 40,
        "image_border_radius": 8,
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "enable_animation": true,
        "animation_delay": "0.2s",
        "heading_size_desktop": 48,
        "heading_size_mobile": 32,
        "subheading_size_desktop": 18,
        "subheading_size_mobile": 16,
        "text_size_desktop": 16,
        "text_size_mobile": 14
      }
    }
  ]
}
{% endschema %}
