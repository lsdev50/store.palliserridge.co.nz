{%- liquid
  assign column_ratio_class = 'welcome-section--' | append: section.settings.column_ratio
  assign content_alignment_class = 'welcome-section--content-' | append: section.settings.content_alignment

  if section.settings.enable_animation
    assign animation_class = ' welcome-section--animated'
  else
    assign animation_class = ''
  endif
-%}

{% capture left_content %}
  {% if section.settings.left_image != blank %}
    <div class="welcome-section__image-wrapper">
      {{ section.settings.left_image | image_url: width: 800 | image_tag: widths: '400, 600, 800, 1000', sizes: '(max-width: 749px) 100vw, (max-width: 1024px) 50vw, 40vw', class: 'welcome-section__image', alt: 'Left column image', loading: 'lazy' }}
    </div>
  {% endif %}

  {% if section.settings.left_text != blank %}
    <div class="welcome-section__text rte">
      {{ section.settings.left_text }}
    </div>
  {% endif %}

  {% if section.settings.button_text != blank and section.settings.button_link != blank %}
    <a href="{{ section.settings.button_link }}" class="welcome-section__button button button--primary">
      {{ section.settings.button_text }}
    </a>
  {% endif %}
{% endcapture %}

{% capture right_content %}
  {% if section.settings.main_heading != blank %}
    <h2 class="welcome-section__heading {{ section.settings.heading_size }}">
      {{ section.settings.main_heading }}
    </h2>
  {% endif %}

  {% if section.settings.sub_heading != blank %}
    <h3 class="welcome-section__sub-heading {{ section.settings.subheading_size }}">
      {{ section.settings.sub_heading }}
    </h3>
  {% endif %}

  {% if section.settings.main_text != blank %}
    <div class="welcome-section__description rte">
      {{ section.settings.main_text }}
    </div>
  {% endif %}

  {% if section.settings.bottom_image_1 != blank or section.settings.bottom_image_2 != blank %}
    <div class="welcome-section__images">
      {% if section.settings.bottom_image_1 != blank %}
        <div class="welcome-section__image-item">
          {{ section.settings.bottom_image_1 | image_url: width: 400 | image_tag: widths: '200, 300, 400', sizes: '(max-width: 749px) 100vw, (max-width: 1024px) 25vw, 20vw', class: 'welcome-section__image', alt: 'Right image 1', loading: 'lazy' }}
        </div>
      {% endif %}

      {% if section.settings.bottom_image_2 != blank %}
        <div class="welcome-section__image-item">
          {{ section.settings.bottom_image_2 | image_url: width: 400 | image_tag: widths: '200, 300, 400', sizes: '(max-width: 749px) 100vw, (max-width: 1024px) 25vw, 20vw', class: 'welcome-section__image', alt: 'Right image 2', loading: 'lazy' }}
        </div>
      {% endif %}
    </div>
  {% endif %}
{% endcapture %}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--{{ section.settings.section_width }} welcome-section color-{{ section.settings.color_scheme }} spacing-style {{ column_ratio_class }} {{ content_alignment_class }}{{ animation_class }}"
  style="
    {% render 'spacing-padding', settings: section.settings %}
    {% render 'border-override', settings: section.settings %}
    --column-gap: {{ section.settings.column_gap }}px;
    --image-border-radius: {{ section.settings.image_border_radius }}px;
    --right-images-gap: {{ section.settings.right_images_gap }}px;
    --welcome-heading-font: var(--font-{{ section.settings.heading_font }}--family, var(--font-heading-family));
    --welcome-text-font: var(--font-{{ section.settings.text_font }}--family, var(--font-body-family));
    --animation-delay: {{ section.settings.animation_delay }};
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="welcome-section__grid">
    <div class="welcome-section__column welcome-section__column--left">
      {{ left_content }}
    </div>
    <div class="welcome-section__column welcome-section__column--right">
      {{ right_content }}
    </div>
  </div>
</div>

{% stylesheet %}
.welcome-section {
  --animation-duration: 0.8s;
}

.welcome-section__grid {
  display: grid;
  gap: var(--column-gap);
  align-items: start;
}

.welcome-section--equal .welcome-section__grid {
  grid-template-columns: 1fr 1fr;
}

.welcome-section--wide-left .welcome-section__grid {
  grid-template-columns: 3fr 2fr;
}

.welcome-section--wide-right .welcome-section__grid {
  grid-template-columns: 2fr 3fr;
}

.welcome-section--content-left .welcome-section__column--left {
  text-align: left;
}

.welcome-section--content-center .welcome-section__column--left {
  text-align: center;
}

.welcome-section--content-right .welcome-section__column--left {
  text-align: right;
}

.welcome-section__column {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.welcome-section__image-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: var(--image-border-radius);
}

.welcome-section__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.welcome-section__image-wrapper:hover .welcome-section__image {
  transform: scale(1.03);
}

.welcome-section__text,
.welcome-section__description {
  font-size: 1rem;
  line-height: 1.6;
  font-family: var(--welcome-text-font);
  font-weight: var(--welcome-text-font-weight);
  color: currentColor;
}

.welcome-section__heading {
  margin: 0 0 0.5rem 0;
  font-family: var(--welcome-heading-font);
  line-height: 1.2;
  color: currentColor;
}

.welcome-section__sub-heading {
  margin: 0;
  opacity: 0.8;
  font-family: var(--welcome-heading-font);
  line-height: 1.3;
  color: currentColor;
}

.welcome-section__button {
  display: inline-flex;
  align-self: flex-start;
  margin-top: 0.5rem;
}

.welcome-section--content-center .welcome-section__button {
  align-self: center;
}

.welcome-section--content-right .welcome-section__button {
  align-self: flex-end;
}

.welcome-section__images {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--right-images-gap);
  margin-top: auto;
}

.welcome-section__image-item {
  position: relative;
  overflow: hidden;
  border-radius: var(--image-border-radius);
  aspect-ratio: 1 / 1;
}

.welcome-section__image-item .welcome-section__image {
  height: 100%;
  width: 100%;
  object-fit: cover;
}

.welcome-section--animated {
  opacity: 0;
  animation: fadeInUp var(--animation-duration) ease forwards;
  animation-delay: var(--animation-delay);
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (prefers-reduced-motion: reduce) {
  .welcome-section--animated {
    animation: none;
    opacity: 1;
  }
}

@media screen and (max-width: 749px) {
  .welcome-section__grid {
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .welcome-section__column {
    gap: 1rem;
  }

  .welcome-section__images {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .welcome-section__image-item {
    aspect-ratio: 16 / 9;
  }

  .welcome-section--content-left .welcome-section__button,
  .welcome-section--content-center .welcome-section__button,
  .welcome-section--content-right .welcome-section__button {
    align-self: flex-start;
  }
}
{% endstylesheet %}

{% schema %}
