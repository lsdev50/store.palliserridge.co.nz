          "type": "url",
          "id": "button_link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "button_open_new_tab",
          "label": "Open in new tab",
          "default": false
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            {
              "value": "button",
              "label": "Primary"
            },
            {
              "value": "button-secondary",
              "label": "Secondary"
            },
            {
              "value": "link",
              "label": "Link"
            },
            {
              "value": "button-unstyled",
              "label": "Unstyled"
            }
          ],
          "default": "link"
        },
        {
          "type": "header",
          "content": "Appearance"
        },
        {
          "type": "color_scheme",
          "id": "card_color_scheme",
          "label": "Color scheme"
        },
        {
          "type": "header",
          "content": "Background Image"
        },
