          "options": [
            { "value": "center", "label": "Center" },
            { "value": "top", "label": "Top" },
            { "value": "bottom", "label": "Bottom" },
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center",
          "visible_if": "{{ block.settings.enable_background_image }}"
        },
        {
          "type": "header",
          "content": "Card Spacing"
        },
        {
          "type": "range",
          "id": "card_padding_vertical",
          "label": "Card padding (top & bottom)",
          "min": 0,
          "max": 80,
          "step": 4,
          "unit": "px",
          "default": 48
        },
        {
          "type": "range",
          "id": "card_padding_horizontal",
          "label": "Card padding (left & right)",
          "min": 0,
          "max": 80,
          "step": 4,
          "unit": "px",
          "default": 48
        },
        {
          "type": "header",
          "content": "Borders"
        },
        {
          "type": "select",
          "id": "card_border_style",
          "label": "Borders",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "solid", "label": "Solid" }
          ],
          "default": "solid"
        },
        {
          "type": "range",
          "id": "card_border_width",
          "label": "Border width",
          "min": 1,
          "max": 5,
          "step": 0.5,
          "unit": "px",
          "default": 1,
          "visible_if": "{{ block.settings.card_border_style != 'none' }}"
        },
        {
          "type": "range",
          "id": "card_border_radius",
          "label": "Border radius",
          "min": 0,
          "max": 40,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "checkbox",
          "id": "card_shadow",
          "label": "Enable card hover shadow",
          "default": false
        },
        {
          "type": "header",
          "content": "Typography"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
